model Model
	culture: en-GB
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-NL
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Data Model'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Funtion Parameter'

	annotation PBI_QueryGroupOrder = 1

annotation PBI_QueryOrder = ["Sales_State","Sales_Promotion","Sales_product_Sub_Category","Sales_Product","Sales_Data","Sales_Channel","Date","Query1","Metrics","Metrics_2"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DevMode"]

ref table Sales_State
ref table Sales_Promotion
ref table Sales_product_Sub_Category
ref table Sales_Product
ref table Sales_Data
ref table Sales_Channel
ref table Metrics
ref table Date
ref table Metrics_2

ref cultureInfo en-GB

